# ── Copie ce fichier en .env et remplis les valeurs ──────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Firecrawl (scraping site cible)
FIRECRAWL_API_KEY=fc-...

# DataForSEO (SERP + PAA + keyword clustering)
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your_password

# Google Search Console
# Télécharge le fichier credentials OAuth2 depuis Google Cloud Console
# (type : Desktop App, scope : Search Console Read-Only)
GSC_CREDENTIALS_FILE=gsc_credentials.json
GSC_SITE_URL=https://www.dedecker.be/

# Site cible pour le style profile
TARGET_SITE_URL=https://www.dedecker.be

# Cache du style profile (sera créé automatiquement)
STYLE_PROFILE_CACHE=style_profile.json

# Webhook server
WEBHOOK_PORT=8080
WEBHOOK_SECRET=                   # laisser vide pour désactiver l'auth

# Dossier de sortie des articles
OUTPUT_DIR=outputs
